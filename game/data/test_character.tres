[sub_resource type="Resource" id="light_kf_recovery"]
script = ExtResource("3_kf")
frame_start = 7
frame_end = 12
hurtboxes = Array[Box]([SubResource("hurt_stand")])
hitboxes = Array[HitBox]([])
throwboxes = Array[Box]([])
has_motion = false

[sub_resource type="Resource" id="light_state"]
