; --- button_map: BUTTON_0 -> LIGHT (state 10), direction-agnostic. ---
[sub_resource type="Resource" id="btn_light"]
script = ExtResource("6_btn")
button_index = 0
required_direction = 0
motion = 0
target_state_id = 10

; --- physics: walk 2 units/tick baked fixed-point (131072). ---
[sub_resource type="Resource" id="phys"]
script = ExtResource("7_phys")
walk_speed = 131072
gravity = 0
jump_velocity = 0

[resource]
script = ExtResource("1_char")
id = 1
states = Array[MoveState]([SubResource("idle_state"), SubResource("walk_state"), SubResource("light_state"), SubResource("hitstun_state"), SubResource("blockstun_state")])
button_map = Array[ButtonMapEntry]([SubResource("btn_light")])
physics = SubResource("phys")
default_pushbox = SubResource("pushbox_default")
idle_state_id = 0
